  "role": "ADMIN"
}

###

# @name updateMemberRoleToMember
# Demote an admin to MEMBER (only the community owner can perform this)
PATCH http://localhost:3000/api/communities/cc7ad9a8-2788-44e6-a316-9149a949237c/role
Content-Type: application/json
Origin: http://localhost:3000

{
  "memberId": "k8YfJtUnVfUraA1nazYp0T8ZoBljKuss",
  "role": "MEMBER"
}

